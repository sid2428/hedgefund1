# --- Postgres ---
POSTGRES_PASSWORD=devpassword
POSTGRES_USER=mosaic
POSTGRES_DB=mosaic

# --- AI APIs ---
# Groq (required) - https://console.groq.com
# Default model is llama-3.3-70b-versatile (128k ctx). Override with GROQ_MODEL.
GROQ_API_KEY=gsk-REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (required, embeddings only) - https://platform.openai.com
OPENAI_API_KEY=sk-REPLACE_ME

# --- SEC EDGAR ---
# Required by EDGAR ToS. Use a real contact address.
EDGAR_USER_AGENT=Mosaic Research research@yourdomain.com

# --- Connection strings ---
# Local (without Docker) defaults:
#   DATABASE_URL=postgresql+asyncpg://mosaic:devpassword@localhost:5432/mosaic
#   REDIS_URL=redis://localhost:6379/0
# Inside docker-compose, hostnames resolve to the service names:
DATABASE_URL=postgresql+asyncpg://mosaic:devpassword@postgres:5432/mosaic
REDIS_URL=redis://redis:6379/0

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend ---
VITE_API_URL=http://localhost:8000
